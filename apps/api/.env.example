# Default local dev (SQLite — no Docker required)
DATABASE_URL="file:./dev.db"
JWT_SECRET="dev-secret-change-me"
PORT=3001

# Docker PostgreSQL (when Docker Desktop is installed and fix:dev selects Postgres)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gametracker?schema=public"

# Hosted PostgreSQL (Neon, Supabase, Render, etc.)
# DATABASE_URL="postgresql://user:pass@host/db?schema=public"

# Production — see DEPLOY.md
# NODE_ENV=production
# CORS_ORIGIN=https://your-frontend.example.com
# WEB_DIST_PATH=../../web/dist
# UPLOAD_DIR=uploads
