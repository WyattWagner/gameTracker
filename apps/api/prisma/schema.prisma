generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  monsters     Monster[]
  quests       Quest[]
  encounters   Encounter[]
  drops        Drop[]
}

model Game {
  id       String    @id
  name     String
  monsters Monster[]
  quests   Quest[]
  drops    Drop[]
}

model Monster {
  id                 String        @id @default(cuid())
  gameId             String
  userId             String
  name               String
  imageUrl           String?
  favoriteWeaponUsed String?
  lastEncounterAt    DateTime?
  numberOfHunts      Int           @default(0)
  wins               Int           @default(0)
  losses             Int           @default(0)
  captures           Int           @default(0)
  failedQuests       Int           @default(0)
  notes              String?
  metadata           Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  game               Game          @relation(fields: [gameId], references: [id])
  user               User          @relation(fields: [userId], references: [id])
  questMonsters      QuestMonster[]
  encounters         Encounter[]
  drops              Drop[]

  @@index([userId, gameId])
}

model Quest {
  id               String         @id @default(cuid())
  gameId           String
  userId           String
  name             String
  completionStatus String
  timeTakenSeconds Int?
  cartCount        Int            @default(0)
  rewards          String?
  notes            String?
  weaponUsed       String?
  isMultiplayer    Boolean        @default(false)
  metadata         Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  game             Game           @relation(fields: [gameId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
  questMonsters    QuestMonster[]
  encounters       Encounter[]
  drops            Drop[]

  @@index([userId, gameId])
}

model QuestMonster {
  questId   String
  monsterId String
  quest     Quest   @relation(fields: [questId], references: [id], onDelete: Cascade)
  monster   Monster @relation(fields: [monsterId], references: [id], onDelete: Cascade)

  @@id([questId, monsterId])
}

model Encounter {
  id            String   @id @default(cuid())
  questId       String
  monsterId     String
  userId        String
  encounterDate DateTime @default(now())
  result        String
  metadata      Json?
  createdAt     DateTime @default(now())
  quest         Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  monster       Monster  @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId, encounterDate])
}

model Drop {
  id              String   @id @default(cuid())
  gameId          String
  userId          String
  sourceMonsterId String
  questId         String?
  dropName        String
  rarity          String
  quantity        Int      @default(1)
  dateObtained    DateTime @default(now())
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  game            Game     @relation(fields: [gameId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
  sourceMonster   Monster  @relation(fields: [sourceMonsterId], references: [id])
  quest           Quest?   @relation(fields: [questId], references: [id])

  @@index([userId, gameId])
}
