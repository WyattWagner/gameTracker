# Leave unset when the API serves the built web app on the same domain.
# Required for Vercel / split hosting (static frontend + API on another host):
# VITE_API_URL=https://your-api.onrender.com/api/v1
#
# Optional — auto-derived from VITE_API_URL if omitted. Set when uploads are on a CDN:
# VITE_API_ORIGIN=https://your-api.onrender.com
