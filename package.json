{
  "name": "cursor-game-tracker",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "dev:api": "npm run build:packages && npm run db:seed --workspace api && npm run dev --workspace api",
    "dev:web": "npm run dev --workspace web",
    "fix:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/fix-dev.ps1",
    "test:e2e": "npm run test:e2e --workspace web",
    "db:migrate": "npm run db:migrate --workspace api",
    "db:seed": "npm run db:seed --workspace api",
    "build:packages": "npm run build --workspace @game-tracker/shared && npm run build --workspace @game-tracker/domain",
    "build:prod": "npm run build:packages && npm run build:prod --workspace api && npm run build --workspace web",
    "start:prod": "npm run start:prod --workspace api",
    "docker:up": "docker compose up -d postgres",
    "docker:down": "docker compose down",
    "docker:prod": "docker compose --profile production up --build",
    "catalog:generate": "node scripts/generate-mhw-catalog.mjs",
    "save": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/commit-push.ps1",
    "git-all-push": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/commit-push.ps1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
